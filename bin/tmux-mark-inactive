#!/usr/bin/env bash
# Clears the @active flag on a session so it drops out of the filtered
# chooser (prefix s) without waiting for the 4h decay. Bound to prefix M.

session="$1"
[ -z "$session" ] && exit 0

tmux set-option -ut "$session" @active
tmux set-option -ut "$session" @last_attached
tmux display-message "Marked '$session' inactive"

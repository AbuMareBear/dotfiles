{
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git log:*)",
      "Bash(git push:*)",
      "Bash(git stash)",
      "Bash(git stash list)",
      "Bash(git stash pop)",
      "Bash(git stash push:*)",
      "Bash(git stash show:*)",
      "Bash(locate:*)",
      "Bash(sed -n:*)",
      "Bash(bin/normalize-i18n:*)",
      "Bash(bundle exec i18n-tasks check-normalized)",
      "Bash(bundle exec i18n-tasks unused)",
      "Bash(bin/rubocop:*)",
      "Bash(bin/lint:*)",
      "Bash(bin/rails db:rollback:*)",
      "Bash(gem build:*)",
      "Bash(gem contents:*)",
      "Bash(tar -t*)",
      "Bash(tar -xO*)",
      "Bash(tmux display-message:*)",
      "Read(//Users/abdullahhashim/.claude/**)",
      "Read(.claude/**)"
    ],
    "deny": [
      "Bash(gem push:*)"
    ]
  },
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "session=$([ -n \"$TMUX\" ] && tmux display-message -p '#S' 2>/dev/null); session=${session:-default}; cat ~/.cache/claude-vim-buffers-\"$session\".txt 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "effortLevel": "high"
}

{
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(git add:*)",
      "Bash(git checkout -b:*)",
      "Bash(git commit:*)",
      "Bash(git log:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git stash)",
      "Bash(git stash list)",
      "Bash(git stash pop)",
      "Bash(git stash push:*)",
      "Bash(git stash show:*)",
      "Bash(locate:*)",
      "Bash(sed -n:*)",
      "Bash(bin/normalize-i18n:*)",
      "Bash(bundle exec i18n-tasks:*)",
      "Bash(dotenv -e .env.jest -- npx prisma migrate deploy)",
      "Bash(npx dotenv-cli -e .env.jest -- npx prisma migrate deploy 2>&1 | tail -30)",
      "Bash(bin/rubocop:*)",
      "Bash(bin/lint:*)",
      "Bash(bin/ci:*)",
      "Bash(bin/rails db:rollback:*)",
      "Bash(bin/rails g:*)",
      "Bash(bin/rails generate:*)",
      "Bash(gem build:*)",
      "Bash(gem contents:*)",
      "Bash(gh auth status)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr view:*)",
      "Bash(tar -t*)",
      "Bash(tar -xO*)",
      "Bash(tmux display-message:*)",
      "Read(//Users/abdullahhashim/.claude/**)",
      "Read(.claude/**)"
    ],
    "deny": [
      "Bash(gem push:*)"
    ]
  },
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/code/personal/dotfiles/claude_hooks/block-bash-guardrails.sh\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TMUX_PANE\" ] && echo busy > /tmp/claude-tmux-${TMUX_PANE#%}"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); message=$(echo \"$input\" | jq -r '.message // empty'); session=$([ -n \"$TMUX\" ] && tmux display-message -p '#S' 2>/dev/null); osascript -e \"display notification \\\"${message:-Claude needs attention}\\\" with title \\\"Claude Code${session:+ ($session)}\\\"\"; case \"$session\" in teamwork*) sound=Glass;; catberry*) sound=Hero;; forge*) sound=Submarine;; *) sound=Morse;; esac; afplay /System/Library/Sounds/$sound.aiff &"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TMUX_PANE\" ] && echo idle > /tmp/claude-tmux-${TMUX_PANE#%}"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "session=$([ -n \"$TMUX\" ] && tmux display-message -p '#S' 2>/dev/null); session=${session:-default}; cat ~/.cache/claude-vim-buffers-\"$session\".txt 2>/dev/null || true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TMUX_PANE\" ] && echo busy > /tmp/claude-tmux-${TMUX_PANE#%}"
          }
        ]
      }
    ]
  },
  "effortLevel": "high",
  "preferredNotifChannel": "terminal_bell"
}

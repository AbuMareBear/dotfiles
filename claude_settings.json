{
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(locate:*)"
    ]
  },
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat ~/.cache/claude-vim-buffers.txt 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "effortLevel": "high"
}
